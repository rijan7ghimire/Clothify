@page
@model Clothify.Web.Pages.Auth.LoginModel
@{
    ViewData["Title"] = "Login";
    ViewData["HideNav"] = true;
    ViewData["HideLayout"] = true;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
    <title>Login - Clothify</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/clothify.css" />
</head>
<body style="padding-bottom:0">
    <div class="container" style="max-width:440px;padding-top:60px">
        <!-- Logo -->
        <div class="text-center mb-8">
            <h1 style="font-size:2rem;font-weight:700;letter-spacing:0.15em;text-transform:uppercase">CLOTHIFY</h1>
            <h2 class="text-2xl font-bold mt-6">Welcome back</h2>
            <p class="text-secondary mt-2">Sign in to continue shopping</p>
        </div>

        <!-- Login Form -->
        <form method="post">
            @Html.AntiForgeryToken()

            @if (!string.IsNullOrEmpty(Model.ErrorMessage))
            {
                <div style="background:#FFEBEE;color:var(--color-error);padding:var(--space-3) var(--space-4);border-radius:var(--radius-md);margin-bottom:var(--space-4);font-size:var(--font-size-sm)">
                    @Model.ErrorMessage
                </div>
            }

            <div class="form-group">
                <label class="form-label">Email Address</label>
                <input type="email" name="Email" class="form-input" placeholder="you@example.com" value="@Model.Email" required />
            </div>

            <div class="form-group">
                <label class="form-label">Password</label>
                <div class="form-input-icon">
                    <input type="password" name="Password" class="form-input" placeholder="Enter your password" required minlength="8" />
                    <span class="icon" data-toggle-password>
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
                    </span>
                </div>
            </div>

            <div class="flex items-center justify-between mb-6">
                <label class="checkbox">
                    <input type="checkbox" name="RememberMe" />
                    <span>Remember me</span>
                </label>
                <span class="text-sm text-light">Forgot Password?</span>
            </div>

            <button type="submit" class="btn btn-primary btn-block btn-lg">Sign In</button>
        </form>

        <!-- Divider -->
        <div class="divider">new to Clothify?</div>

        <!-- Sign Up Link -->
        <p class="text-center mt-6 text-sm">
            Don't have an account?
            <a href="/Auth/Register" class="font-semibold text-accent">Sign Up</a>
        </p>
    </div>
    <script src="~/js/clothify.js"></script>
</body>
</html>
