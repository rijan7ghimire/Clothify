@page
@model Clothify.Web.Pages.Auth.LoginModel
@{
    ViewData["Title"] = "Login";
    ViewData["HideNav"] = true;
    ViewData["HideLayout"] = true;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
    <title>Login - Clothify</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/clothify.css" />
</head>
<body style="padding-bottom:0">
    <div class="container" style="max-width:440px;padding-top:60px">
        <!-- Logo -->
        <div class="text-center mb-8">
            <h1 style="font-size:2rem;font-weight:700;letter-spacing:0.15em;text-transform:uppercase">CLOTHIFY</h1>
            <h2 class="text-2xl font-bold mt-6">Welcome back</h2>
            <p class="text-secondary mt-2">Sign in to continue shopping</p>
        </div>

        <!-- Login Form -->
        <form method="post">
            @Html.AntiForgeryToken()

            @if (!string.IsNullOrEmpty(Model.ErrorMessage))
            {
                <div style="background:#FFEBEE;color:var(--color-error);padding:var(--space-3) var(--space-4);border-radius:var(--radius-md);margin-bottom:var(--space-4);font-size:var(--font-size-sm)">
                    @Model.ErrorMessage
                </div>
            }

            <div class="form-group">
                <label class="form-label">Email Address</label>
                <input type="email" name="Email" class="form-input" placeholder="you@example.com" value="@Model.Email" required />
            </div>

            <div class="form-group">
                <label class="form-label">Password</label>
                <div class="form-input-icon">
                    <input type="password" name="Password" class="form-input" placeholder="Enter your password" required minlength="8" />
                    <span class="icon" data-toggle-password>
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
                    </span>
                </div>
            </div>

            <div class="flex items-center justify-between mb-6">
                <label class="checkbox">
                    <input type="checkbox" name="RememberMe" />
                    <span>Remember me</span>
                </label>
                <a href="/Auth/ForgotPassword" class="text-sm font-medium text-accent">Forgot Password?</a>
            </div>

            <button type="submit" class="btn btn-primary btn-block btn-lg">Sign In</button>
        </form>

        <!-- Divider -->
        <div class="divider">or continue with</div>

        <!-- Social Login -->
        <div class="flex flex-col gap-3">
            <button class="btn btn-outlined btn-block">
                <svg width="20" height="20" viewBox="0 0 24 24"><path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 01-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z" fill="#4285F4"/><path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/><path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/><path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/></svg>
                Continue with Google
            </button>
        </div>

        <!-- Sign Up Link -->
        <p class="text-center mt-6 text-sm">
            Don't have an account?
            <a href="/Auth/Register" class="font-semibold text-accent">Sign Up</a>
        </p>
    </div>
    <script src="~/js/clothify.js"></script>
</body>
</html>
