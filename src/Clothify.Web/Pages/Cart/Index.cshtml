@page "/Cart"
@model Clothify.Web.Pages.Cart.CartModel
@{
    ViewData["Title"] = "Cart";
    ViewData["ShowBack"] = true;
    ViewData["PageTitle"] = "My Cart";
    ViewData["ActiveNav"] = "cart";
}

@if (Model.Cart != null && Model.Cart.Items.Any())
{
    <div class="px-4 py-2 flex items-center justify-between">
        <span class="text-sm text-secondary">@Model.Cart.ItemCount items</span>
        <button class="text-sm text-error font-medium">Clear All</button>
    </div>

    <!-- Cart Items -->
    @foreach (var item in Model.Cart.Items)
    {
        <div class="cart-item">
            <div class="cart-item__image">
                <div style="width:100%;height:100%;background:var(--color-surface);display:flex;align-items:center;justify-content:center;font-size:1.5rem">👕</div>
            </div>
            <div class="cart-item__info">
                <div>
                    <h3 class="cart-item__name">@item.ProductName</h3>
                    <p class="cart-item__variant">@item.Size · @item.Color</p>
                </div>
                <div class="cart-item__bottom">
                    <span class="cart-item__price">Rs. @item.Subtotal.ToString("N2")</span>
                    <div class="qty-selector">
                        <button class="qty-minus" @(item.Quantity <= 1 ? "disabled" : "")>−</button>
                        <span class="qty-selector__count">@item.Quantity</span>
                        <button class="qty-plus">+</button>
                    </div>
                </div>
            </div>
            <button style="align-self:flex-start;color:var(--color-text-light);padding:4px">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 01-2 2H7a2 2 0 01-2-2V6m3 0V4a2 2 0 012-2h4a2 2 0 012 2v2"/></svg>
            </button>
        </div>
    }

    <!-- Coupon -->
    <div class="px-4 py-4">
        <div class="flex gap-2">
            <input type="text" class="form-input flex-1" placeholder="Enter promo code" />
            <button class="btn btn-outlined">Apply</button>
        </div>
    </div>

    <!-- Order Summary -->
    <div class="order-summary">
        <div class="order-summary__row">
            <span>Subtotal</span>
            <span>Rs. @Model.Cart.Subtotal.ToString("N2")</span>
        </div>
        @if (Model.Cart.Discount > 0)
        {
            <div class="order-summary__row">
                <span>Discount</span>
                <span class="discount">-Rs. @Model.Cart.Discount.ToString("N2")</span>
            </div>
        }
        <div class="order-summary__row">
            <span>Shipping</span>
            <span>@(Model.Cart.ShippingCost == 0 ? "Free" : $"${Model.Cart.ShippingCost:N2}")</span>
        </div>
        <div class="order-summary__row">
            <span>Tax</span>
            <span>Rs. @Model.Cart.Tax.ToString("N2")</span>
        </div>
        <div class="order-summary__row total">
            <span>Total</span>
            <span>Rs. @Model.Cart.Total.ToString("N2")</span>
        </div>
    </div>

    <div style="height:80px"></div>

    <!-- Checkout Button -->
    <div class="sticky-bottom">
        <a href="/Checkout" class="text-center text-sm text-accent font-medium" style="display:block;margin-bottom:var(--space-2)">Continue Shopping</a>
        <a href="/Checkout" class="btn btn-primary btn-block btn-lg">Proceed to Checkout — Rs. @Model.Cart.Total.ToString("N2")</a>
    </div>
}
else
{
    <div class="empty-state">
        <div class="empty-state__icon">🛒</div>
        <h3 class="empty-state__title">Your cart is empty</h3>
        <p class="empty-state__text">Looks like you haven't added anything yet</p>
        <a href="/" class="btn btn-primary">Start Shopping</a>
    </div>
}
