@page "/Checkout"
@model Clothify.Web.Pages.Checkout.CheckoutModel
@{
    ViewData["Title"] = "Checkout";
    ViewData["ShowBack"] = true;
    ViewData["PageTitle"] = "Checkout";
    ViewData["HideNav"] = true;
}

@if (Model.Cart != null)
{
    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div style="background:#FFEBEE;color:#C62828;padding:12px 16px;font-size:14px">@Model.ErrorMessage</div>
    }

    <!-- Order Items Preview -->
    <div class="px-4 py-3">
        <h3 class="text-sm font-semibold mb-2">Your Order (@Model.Cart.ItemCount items)</h3>
        <div style="display:flex;gap:8px;overflow-x:auto;padding-bottom:8px">
            @foreach (var item in Model.Cart.Items)
            {
                <div style="min-width:60px;text-align:center">
                    <div style="width:60px;height:60px;border-radius:8px;overflow:hidden;background:var(--color-surface)">
                        <img src="@item.ImageUrl" alt="@item.ProductName" style="width:100%;height:100%;object-fit:cover" />
                    </div>
                    <span class="text-xs">x@item.Quantity</span>
                </div>
            }
        </div>
    </div>

    <form method="post" class="px-4">
        @Html.AntiForgeryToken()

        <!-- Shipping Address -->
        <div class="flex items-center justify-between mb-3">
            <h3 class="text-lg font-bold">Shipping Address</h3>
            @if (!string.IsNullOrEmpty(Model.UserFullName))
            {
                <label class="checkbox" style="min-height:auto">
                    <input type="checkbox" id="autofill-check" onchange="toggleAutofill(this.checked)" />
                    <span class="text-sm">Same as me</span>
                </label>
            }
        </div>

        <div class="form-group">
            <label class="form-label">Full Name</label>
            <input type="text" name="FullName" id="af-name" class="form-input" placeholder="Ram Sharma" required
                   value="@(Model.SavedAddress?.FullName ?? "")" />
        </div>
        <div class="form-group">
            <label class="form-label">Street Address</label>
            <input type="text" name="StreetLine1" id="af-street" class="form-input" placeholder="Putalisadak, Kathmandu" required
                   value="@(Model.SavedAddress?.StreetLine1 ?? "")" />
        </div>
        <div class="form-group">
            <label class="form-label">Landmark (Optional)</label>
            <input type="text" name="StreetLine2" id="af-street2" class="form-input" placeholder="Near Shankar Dev Campus"
                   value="@(Model.SavedAddress?.StreetLine2 ?? "")" />
        </div>
        <div class="flex gap-3">
            <div class="form-group flex-1">
                <label class="form-label">City</label>
                <input type="text" name="City" id="af-city" class="form-input" placeholder="Kathmandu" required
                       value="@(Model.SavedAddress?.City ?? "")" />
            </div>
            <div class="form-group flex-1">
                <label class="form-label">State/Province</label>
                <input type="text" name="State" id="af-state" class="form-input" placeholder="Bagmati" required
                       value="@(Model.SavedAddress?.State ?? "")" />
            </div>
        </div>
        <div class="flex gap-3">
            <div class="form-group flex-1">
                <label class="form-label">ZIP Code</label>
                <input type="text" name="ZipCode" id="af-zip" class="form-input" placeholder="44600" required
                       value="@(Model.SavedAddress?.ZipCode ?? "")" />
            </div>
            <div class="form-group flex-1">
                <label class="form-label">Phone</label>
                <input type="tel" name="Phone" id="af-phone" class="form-input" placeholder="+977-98XXXXXXXX" required
                       value="@(Model.SavedAddress?.Phone ?? Model.UserPhone ?? "")" />
            </div>
        </div>

        <!-- Shipping Method -->
        <h3 class="text-lg font-bold mb-3 mt-4">Shipping Method</h3>
        <div class="flex flex-col gap-2 mb-4">
            <label class="card p-3 flex items-center gap-3 border" style="cursor:pointer;border-radius:var(--radius-md)">
                <input type="radio" name="ShippingMethod" value="Standard" checked />
                <div class="flex-1">
                    <div class="flex justify-between"><span class="font-medium text-sm">Standard (5-7 days)</span><span class="font-semibold text-sm text-success">Free</span></div>
                </div>
            </label>
            <label class="card p-3 flex items-center gap-3 border" style="cursor:pointer;border-radius:var(--radius-md)">
                <input type="radio" name="ShippingMethod" value="Express" />
                <div class="flex-1">
                    <div class="flex justify-between"><span class="font-medium text-sm">Express (2-3 days)</span><span class="font-semibold text-sm">Rs. 500</span></div>
                </div>
            </label>
        </div>

        <!-- Payment Method -->
        <h3 class="text-lg font-bold mb-3 mt-4">Payment Method</h3>
        <div class="flex flex-col gap-2 mb-4">
            <label class="card p-3 flex items-center gap-3 border" style="cursor:pointer;border-radius:var(--radius-md)">
                <input type="radio" name="paymentMethod" value="Khalti" checked />
                <div class="flex-1 flex items-center gap-2">
                    <span style="background:#5C2D91;color:white;padding:2px 8px;border-radius:4px;font-size:12px;font-weight:700">Khalti</span>
                    <span class="text-sm">Pay with Khalti</span>
                </div>
            </label>
            <label class="card p-3 flex items-center gap-3 border" style="cursor:pointer;border-radius:var(--radius-md)">
                <input type="radio" name="paymentMethod" value="eSewa" />
                <div class="flex-1 flex items-center gap-2">
                    <span style="background:#60BB46;color:white;padding:2px 8px;border-radius:4px;font-size:12px;font-weight:700">eSewa</span>
                    <span class="text-sm">Pay with eSewa</span>
                </div>
            </label>
            <label class="card p-3 flex items-center gap-3 border" style="cursor:pointer;border-radius:var(--radius-md)">
                <input type="radio" name="paymentMethod" value="COD" />
                <div class="flex-1 flex items-center gap-2">
                    <span style="background:var(--color-primary);color:white;padding:2px 8px;border-radius:4px;font-size:12px;font-weight:700">COD</span>
                    <span class="text-sm">Cash on Delivery</span>
                </div>
            </label>
        </div>

        <!-- Order Summary -->
        <div class="order-summary border mb-4" style="border-radius:var(--radius-lg)">
            <div class="order-summary__row"><span>Subtotal</span><span>Rs. @Model.Cart.Subtotal.ToString("N2")</span></div>
            <div class="order-summary__row"><span>Shipping</span><span>@(Model.Cart.ShippingCost == 0 ? "Free" : $"${Model.Cart.ShippingCost:N2}")</span></div>
            <div class="order-summary__row"><span>Tax</span><span>Rs. @Model.Cart.Tax.ToString("N2")</span></div>
            <div class="order-summary__row total"><span>Total</span><span>Rs. @Model.Cart.Total.ToString("N2")</span></div>
        </div>

        <button type="submit" class="btn btn-primary btn-block btn-lg mb-6">
            Place Order &mdash; Rs. @Model.Cart.Total.ToString("N2")
        </button>
    </form>

    <script>
        function toggleAutofill(checked) {
            if (checked) {
                document.getElementById('af-name').value = '@(Model.UserFullName?.Replace("'", "\\'") ?? "")';
                document.getElementById('af-phone').value = '@(Model.UserPhone?.Replace("'", "\\'") ?? "")';
                @if (Model.SavedAddress != null)
                {
                    <text>
                    document.getElementById('af-street').value = '@(Model.SavedAddress.StreetLine1.Replace("'", "\\'"))';
                    document.getElementById('af-street2').value = '@(Model.SavedAddress.StreetLine2?.Replace("'", "\\'") ?? "")';
                    document.getElementById('af-city').value = '@(Model.SavedAddress.City.Replace("'", "\\'"))';
                    document.getElementById('af-state').value = '@(Model.SavedAddress.State.Replace("'", "\\'"))';
                    document.getElementById('af-zip').value = '@(Model.SavedAddress.ZipCode.Replace("'", "\\'"))';
                    </text>
                }
            }
        }
    </script>
}
