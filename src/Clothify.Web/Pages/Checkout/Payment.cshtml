@page "/Checkout/Payment"
@model Clothify.Web.Pages.Checkout.PaymentModel
@{
    ViewData["Title"] = "Payment";
    ViewData["HideNav"] = true;
    ViewData["HideLayout"] = true;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
    <title>@Model.Method Payment - Clothify</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/clothify.css" />
</head>
<body style="padding-bottom:0;background:var(--color-surface)">
    <div class="container" style="max-width:440px;padding-top:40px">

        <!-- Payment Gateway Header -->
        <div class="text-center mb-6">
            @if (Model.Method == "Khalti")
            {
                <div style="width:80px;height:80px;border-radius:16px;background:#5C2D91;display:flex;align-items:center;justify-content:center;margin:0 auto;color:white;font-size:24px;font-weight:700">K</div>
                <h2 class="text-xl font-bold mt-4" style="color:#5C2D91">Khalti Payment</h2>
            }
            else
            {
                <div style="width:80px;height:80px;border-radius:16px;background:#60BB46;display:flex;align-items:center;justify-content:center;margin:0 auto;color:white;font-size:24px;font-weight:700">e</div>
                <h2 class="text-xl font-bold mt-4" style="color:#60BB46">eSewa Payment</h2>
            }
            <p class="text-secondary mt-1">Order #@Model.OrderId</p>
        </div>

        <!-- Payment Form -->
        <div class="card p-5" style="border-radius:var(--radius-lg)">
            <div class="text-center mb-6">
                <span class="text-3xl font-bold">$@Model.Amount.ToString("N2")</span>
                <p class="text-sm text-secondary mt-1">Total Amount</p>
            </div>

            <form method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="orderId" value="@Model.OrderId" />
                <input type="hidden" name="method" value="@Model.Method" />

                <div class="form-group">
                    <label class="form-label">@Model.Method ID / Mobile Number</label>
                    <input type="text" name="paymentId" class="form-input" placeholder="98XXXXXXXX" required />
                </div>

                <div class="form-group">
                    <label class="form-label">PIN / MPIN</label>
                    <div class="form-input-icon">
                        <input type="password" name="pin" class="form-input" placeholder="Enter your PIN" required />
                    </div>
                </div>

                <button type="submit" class="btn btn-block btn-lg mt-4"
                        style="background:@(Model.Method == "Khalti" ? "#5C2D91" : "#60BB46");color:white">
                    Pay $@Model.Amount.ToString("N2")
                </button>
            </form>

            <a href="/Orders/Confirmation/@Model.OrderId" class="btn btn-text btn-block mt-3 text-secondary">
                Cancel Payment
            </a>
        </div>

        <p class="text-center text-xs text-light mt-4">
            This is a demo payment gateway simulation.
        </p>
    </div>
</body>
</html>
