@page "/"
@model Clothify.Web.Pages.Home.IndexModel
@{
    ViewData["Title"] = "Home";
    ViewData["ActiveNav"] = "home";
}

<!-- Search Bar -->
<a href="/Products/Search" class="search-bar">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/></svg>
    <input type="text" placeholder="Search for clothes, brands..." readonly />
</a>

<!-- Category Horizontal Scroll -->
<div class="category-scroll">
    <a href="/Products?category=boys" class="category-item">
        <div class="category-item__icon" style="overflow:hidden;padding:0">
            <img src="/images/products/4729.jpg" alt="Boys" style="width:100%;height:100%;object-fit:cover" />
        </div>
        <span class="category-item__label">Boys</span>
    </a>
    <a href="/Products?category=girls" class="category-item">
        <div class="category-item__icon" style="overflow:hidden;padding:0">
            <img src="/images/products/42419.jpg" alt="Girls" style="width:100%;height:100%;object-fit:cover" />
        </div>
        <span class="category-item__label">Girls</span>
    </a>
    <a href="/Products?category=men" class="category-item">
        <div class="category-item__icon" style="overflow:hidden;padding:0">
            <img src="/images/products/9204.jpg" alt="Men Shoes" style="width:100%;height:100%;object-fit:cover" />
        </div>
        <span class="category-item__label">Men Shoes</span>
    </a>
    <a href="/Products?category=women" class="category-item">
        <div class="category-item__icon" style="overflow:hidden;padding:0">
            <img src="/images/products/54118.jpg" alt="Women Shoes" style="width:100%;height:100%;object-fit:cover" />
        </div>
        <span class="category-item__label">Women Shoes</span>
    </a>
    <a href="/Products?category=tops" class="category-item">
        <div class="category-item__icon" style="overflow:hidden;padding:0">
            <img src="/images/products/31127.jpg" alt="Dresses" style="width:100%;height:100%;object-fit:cover" />
        </div>
        <span class="category-item__label">Dresses</span>
    </a>
    <a href="/Products?category=dresses" class="category-item">
        <div class="category-item__icon" style="overflow:hidden;padding:0">
            <img src="/images/products/59051.jpg" alt="Sandals" style="width:100%;height:100%;object-fit:cover" />
        </div>
        <span class="category-item__label">Sandals</span>
    </a>
</div>

<!-- Hero Banners -->
<div class="px-4" style="margin-top:var(--space-3)">
    <!-- Banner 1 -->
    <a href="/Products?category=boys" style="display:block;position:relative;width:100%;aspect-ratio:16/9;border-radius:var(--radius-lg);overflow:hidden;margin-bottom:var(--space-3)">
        <img src="/images/products/4729.jpg" alt="Boys Collection" style="width:100%;height:100%;object-fit:cover;display:block" />
        <div style="position:absolute;inset:0;background:linear-gradient(transparent 40%,rgba(0,0,0,0.7))"></div>
        <div style="position:absolute;bottom:0;left:0;right:0;padding:var(--space-5);color:white">
            <div style="font-size:var(--font-size-xl);font-weight:700">Boys Collection</div>
            <div style="font-size:var(--font-size-sm);opacity:0.9;margin:var(--space-1) 0 var(--space-3)">Up to 40% off selected styles</div>
            <span class="btn btn-primary" style="display:inline-block">Shop Now</span>
        </div>
    </a>

    <!-- Banner 2 -->
    <a href="/Products?category=women" style="display:block;position:relative;width:100%;aspect-ratio:16/9;border-radius:var(--radius-lg);overflow:hidden;margin-bottom:var(--space-3)">
        <img src="/images/products/54118.jpg" alt="Women Footwear" style="width:100%;height:100%;object-fit:cover;display:block" />
        <div style="position:absolute;inset:0;background:linear-gradient(transparent 40%,rgba(0,0,0,0.7))"></div>
        <div style="position:absolute;bottom:0;left:0;right:0;padding:var(--space-5);color:white">
            <div style="font-size:var(--font-size-xl);font-weight:700">Women Footwear</div>
            <div style="font-size:var(--font-size-sm);opacity:0.9;margin:var(--space-1) 0 var(--space-3)">Heels, flats, sandals &amp; more</div>
            <span class="btn btn-primary" style="display:inline-block">Explore</span>
        </div>
    </a>

    <!-- Banner 3 -->
    <a href="/Products?category=men" style="display:block;position:relative;width:100%;aspect-ratio:16/9;border-radius:var(--radius-lg);overflow:hidden">
        <img src="/images/products/9204.jpg" alt="Men Shoes" style="width:100%;height:100%;object-fit:cover;display:block" />
        <div style="position:absolute;inset:0;background:linear-gradient(transparent 40%,rgba(0,0,0,0.7))"></div>
        <div style="position:absolute;bottom:0;left:0;right:0;padding:var(--space-5);color:white">
            <div style="font-size:var(--font-size-xl);font-weight:700">Men's Shoes</div>
            <div style="font-size:var(--font-size-sm);opacity:0.9;margin:var(--space-1) 0 var(--space-3)">Free shipping on orders over Rs. 5,000</div>
            <span class="btn btn-primary" style="display:inline-block">Shop Now</span>
        </div>
    </a>
</div>

<!-- Featured Products -->
<div class="section-header">
    <h2 class="section-header__title">Featured</h2>
    <a href="/Products?featured=true" class="section-header__link">See All</a>
</div>

<div class="grid-2 px-4">
    @if (Model.FeaturedProducts.Any())
    {
        @foreach (var product in Model.FeaturedProducts)
        {
            <a href="/Products/Detail/@product.Id" class="product-card">
                <div class="product-card__image">
                    @if (product.IsOnSale)
                    {
                        <span class="product-card__badge">-@product.DiscountPercent%</span>
                    }
                    <button class="product-card__wishlist" onclick="event.preventDefault();Clothify.toggleWishlist(this,@product.Id)">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z"/></svg>
                    </button>
                    <img src="@product.ImageUrl" alt="@product.Name" loading="lazy" style="width:100%;height:100%;object-fit:cover;position:absolute;top:0;left:0" />
                </div>
                <div class="product-card__info">
                    <span class="product-card__brand">@product.Brand</span>
                    <h3 class="product-card__name">@product.Name</h3>
                    <div class="product-card__price">
                        <span class="current">Rs. @product.Price.ToString("N2")</span>
                        @if (product.OriginalPrice.HasValue)
                        {
                            <span class="original">Rs. @product.OriginalPrice.Value.ToString("N2")</span>
                        }
                    </div>
                </div>
            </a>
        }
    }
    else
    {
        <div class="empty-state"><p class="text-secondary">No featured products yet.</p></div>
    }
</div>

<!-- New Arrivals -->
<div class="section-header mt-6">
    <h2 class="section-header__title">Just Arrived</h2>
    <a href="/Products?sort=newest" class="section-header__link">See All</a>
</div>

<div class="h-scroll">
    @if (Model.NewArrivals.Any())
    {
        @foreach (var product in Model.NewArrivals)
        {
            <a href="/Products/Detail/@product.Id" class="product-card">
                <div class="product-card__image">
                    <span class="product-card__badge new">NEW</span>
                    <img src="@product.ImageUrl" alt="@product.Name" loading="lazy" style="width:100%;height:100%;object-fit:cover;position:absolute;top:0;left:0" />
                </div>
                <div class="product-card__info">
                    <span class="product-card__brand">@product.Brand</span>
                    <h3 class="product-card__name">@product.Name</h3>
                    <div class="product-card__price"><span class="current">Rs. @product.Price.ToString("N2")</span></div>
                </div>
            </a>
        }
    }
    else
    {
        <div class="empty-state"><p class="text-secondary">No new arrivals yet.</p></div>
    }
</div>

<div style="height:var(--space-8)"></div>
