@page "/Orders"
@model Clothify.Web.Pages.Orders.IndexModel
@{
    ViewData["Title"] = "My Orders";
    ViewData["ShowBack"] = true;
    ViewData["PageTitle"] = "My Orders";
    ViewData["ActiveNav"] = "profile";
}

@if (Model.Orders.Items.Any())
{
    <div class="px-4 py-2">
        <span class="text-sm text-secondary">@Model.Orders.TotalCount orders</span>
    </div>

    @foreach (var order in Model.Orders.Items)
    {
        <a href="/Orders/Track/@order.Id" class="card border mx-4 mb-3 p-4" style="display:block;border-radius:var(--radius-lg)">
            <div class="flex justify-between items-start mb-2">
                <div>
                    <span class="text-sm font-bold">@order.OrderNumber</span>
                    <p class="text-xs text-secondary">@order.PlacedAt.ToString("MMM dd, yyyy")</p>
                </div>
                <span class="badge @(order.StatusDisplay switch {
                    "Delivered" => "badge-success",
                    "Confirmed" => "badge-info",
                    "Shipped" => "badge-info",
                    "OutForDelivery" => "badge-info",
                    "Processing" => "badge-warning",
                    "Placed" => "badge-warning",
                    "Cancelled" => "badge-error",
                    _ => "badge-neutral"
                })">@order.StatusDisplay</span>
            </div>

            <!-- Order items preview -->
            <div class="flex gap-2 mb-3" style="overflow-x:auto">
                @foreach (var item in order.Items.Take(4))
                {
                    <div style="width:48px;height:48px;border-radius:6px;overflow:hidden;background:var(--color-surface);flex-shrink:0">
                        <img src="@item.ImageUrl" alt="@item.ProductName" style="width:100%;height:100%;object-fit:cover" />
                    </div>
                }
                @if (order.ItemCount > 4)
                {
                    <div style="width:48px;height:48px;border-radius:6px;background:var(--color-surface);display:flex;align-items:center;justify-content:center;flex-shrink:0">
                        <span class="text-xs text-secondary">+@(order.ItemCount - 4)</span>
                    </div>
                }
            </div>

            <div class="flex justify-between items-center">
                <span class="text-sm text-secondary">@order.ItemCount items</span>
                <span class="text-sm font-bold">$@order.Total.ToString("N2")</span>
            </div>
        </a>
    }
}
else
{
    <div class="empty-state">
        <div class="empty-state__icon" style="font-size:48px">&#128230;</div>
        <h3 class="empty-state__title">No orders yet</h3>
        <p class="empty-state__text">Your order history will appear here</p>
        <a href="/" class="btn btn-primary">Start Shopping</a>
    </div>
}
