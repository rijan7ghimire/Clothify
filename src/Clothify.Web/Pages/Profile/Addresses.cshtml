@page "/Profile/Addresses"
@model Clothify.Web.Pages.Profile.AddressesModel
@{
    ViewData["Title"] = "Saved Addresses";
    ViewData["ShowBack"] = true;
    ViewData["PageTitle"] = "Saved Addresses";
}

<div class="px-4 py-4">
    @if (!string.IsNullOrEmpty(Model.SuccessMessage))
    {
        <div style="background:#E8F5E9;color:#2E7D32;padding:12px 16px;border-radius:var(--radius-md);margin-bottom:16px;font-size:14px">&#10003; @Model.SuccessMessage</div>
    }

    @foreach (var addr in Model.Addresses)
    {
        <div class="card border p-4 mb-3" style="border-radius:var(--radius-lg)">
            <div class="flex justify-between">
                <div>
                    <p class="text-sm font-bold">@addr.FullName</p>
                    <p class="text-xs text-secondary mt-1">@addr.StreetLine1@(addr.StreetLine2 != null ? $", {addr.StreetLine2}" : "")</p>
                    <p class="text-xs text-secondary">@addr.City, @addr.State @addr.ZipCode</p>
                    <p class="text-xs text-secondary">@addr.Phone</p>
                </div>
                <form method="post" asp-page-handler="Delete">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="addressId" value="@addr.Id" />
                    <button type="submit" class="btn-icon" style="color:var(--color-error)" onclick="return confirm('Delete this address?')">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 01-2 2H7a2 2 0 01-2-2V6m3 0V4a2 2 0 012-2h4a2 2 0 012 2v2"/></svg>
                    </button>
                </form>
            </div>
            @if (addr.IsDefault) { <span class="badge badge-success mt-2">Default</span> }
        </div>
    }

    <!-- Add New Address -->
    <h3 class="text-md font-bold mt-6 mb-3">Add New Address</h3>
    <form method="post" asp-page-handler="Add">
        @Html.AntiForgeryToken()
        <div class="form-group"><label class="form-label">Full Name</label><input type="text" name="fullName" class="form-input" required /></div>
        <div class="form-group"><label class="form-label">Street Address</label><input type="text" name="streetLine1" class="form-input" required /></div>
        <div class="form-group"><label class="form-label">Landmark</label><input type="text" name="streetLine2" class="form-input" /></div>
        <div class="flex gap-3">
            <div class="form-group flex-1"><label class="form-label">City</label><input type="text" name="city" class="form-input" required /></div>
            <div class="form-group flex-1"><label class="form-label">State</label><input type="text" name="state" class="form-input" required /></div>
        </div>
        <div class="flex gap-3">
            <div class="form-group flex-1"><label class="form-label">ZIP</label><input type="text" name="zipCode" class="form-input" required /></div>
            <div class="form-group flex-1"><label class="form-label">Phone</label><input type="tel" name="phone" class="form-input" required /></div>
        </div>
        <button type="submit" class="btn btn-primary btn-block">Add Address</button>
    </form>
</div>
