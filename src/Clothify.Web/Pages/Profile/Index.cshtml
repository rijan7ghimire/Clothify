@page "/Profile"
@model Clothify.Web.Pages.Profile.ProfileModel
@{
    ViewData["Title"] = "Profile";
    ViewData["ActiveNav"] = "profile";
}

@if (User.Identity?.IsAuthenticated == true)
{
    <!-- Profile Header -->
    <div class="text-center py-6 px-4">
        <div style="width:80px;height:80px;border-radius:50%;background:var(--color-surface);display:flex;align-items:center;justify-content:center;margin:0 auto;font-size:32px;position:relative">
            👤
            <button style="position:absolute;bottom:0;right:0;width:28px;height:28px;border-radius:50%;background:var(--color-primary);color:white;display:flex;align-items:center;justify-content:center;font-size:12px">
                📷
            </button>
        </div>
        <h2 class="text-lg font-bold mt-3">@(Model.UserProfile?.FirstName ?? "John") @(Model.UserProfile?.LastName ?? "Doe")</h2>
        <p class="text-sm text-secondary">@(Model.UserProfile?.Email ?? "john@example.com")</p>
    </div>

    <!-- Quick Stats -->
    <div class="flex justify-center gap-8 pb-4 border-b">
        <div class="text-center">
            <div class="font-bold text-lg">12</div>
            <div class="text-xs text-secondary">Orders</div>
        </div>
        <div class="text-center">
            <div class="font-bold text-lg">5</div>
            <div class="text-xs text-secondary">Wishlist</div>
        </div>
        <div class="text-center">
            <div class="font-bold text-lg">240</div>
            <div class="text-xs text-secondary">Points</div>
        </div>
    </div>

    <!-- Menu Sections -->
    <div class="profile-menu__section">My Orders</div>
    <a href="/Orders" class="profile-menu__item">
        <div class="left">
            <span>📦</span>
            <span class="text-sm font-medium">My Orders</span>
        </div>
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6"/></svg>
    </a>
    <a href="/Orders/Track/1" class="profile-menu__item">
        <div class="left">
            <span>🚚</span>
            <span class="text-sm font-medium">Track Order</span>
        </div>
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6"/></svg>
    </a>

    <div class="profile-menu__section">Account Settings</div>
    <a href="#" class="profile-menu__item">
        <div class="left">
            <span>👤</span>
            <span class="text-sm font-medium">Personal Information</span>
        </div>
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6"/></svg>
    </a>
    <a href="#" class="profile-menu__item">
        <div class="left">
            <span>📍</span>
            <span class="text-sm font-medium">Saved Addresses</span>
        </div>
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6"/></svg>
    </a>
    <a href="#" class="profile-menu__item">
        <div class="left">
            <span>💳</span>
            <span class="text-sm font-medium">Payment Methods</span>
        </div>
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6"/></svg>
    </a>
    <a href="#" class="profile-menu__item">
        <div class="left">
            <span>🔒</span>
            <span class="text-sm font-medium">Change Password</span>
        </div>
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6"/></svg>
    </a>

    <div class="profile-menu__section">Preferences</div>
    <a href="#" class="profile-menu__item">
        <div class="left">
            <span>🔔</span>
            <span class="text-sm font-medium">Notifications</span>
        </div>
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6"/></svg>
    </a>

    <div class="profile-menu__section">Support</div>
    <a href="#" class="profile-menu__item">
        <div class="left">
            <span>❓</span>
            <span class="text-sm font-medium">Help Center</span>
        </div>
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6"/></svg>
    </a>
    <a href="#" class="profile-menu__item">
        <div class="left">
            <span>ℹ️</span>
            <span class="text-sm font-medium">About Clothify</span>
        </div>
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6"/></svg>
    </a>

    <!-- Logout -->
    <div class="px-4 py-6">
        <form method="post" asp-page="/Profile/Index" asp-page-handler="Logout">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn btn-text btn-block text-error font-semibold">Log Out</button>
        </form>
    </div>

    <p class="text-center text-xs text-light pb-6">Clothify v1.0.0</p>
}
else
{
    <div class="empty-state">
        <div class="empty-state__icon">👤</div>
        <h3 class="empty-state__title">Sign in to your account</h3>
        <p class="empty-state__text">Track orders, save items, and manage your profile</p>
        <a href="/Auth/Login" class="btn btn-primary">Sign In</a>
        <a href="/Auth/Register" class="btn btn-outlined mt-3">Create Account</a>
    </div>
}
