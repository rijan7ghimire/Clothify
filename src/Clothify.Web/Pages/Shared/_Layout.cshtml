<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover" />
    <meta name="theme-color" content="#111111" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <meta name="apple-mobile-web-app-title" content="Clothify" />
    <meta name="mobile-web-app-capable" content="yes" />
    <meta name="application-name" content="Clothify" />
    <meta name="description" content="Mobile-first fashion e-commerce platform" />
    <title>@ViewData["Title"] - Clothify</title>
    <link rel="manifest" href="/manifest.json" />
    <link rel="icon" type="image/svg+xml" href="/icons/icon.svg" />
    <link rel="apple-touch-icon" href="/icons/icon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/clothify.css" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    @if (ViewData["HideLayout"] == null)
    {
        <!-- Top Bar -->
        <header class="top-bar">
            @if (ViewData["ShowBack"] != null)
            {
                <a href="javascript:history.back()" class="top-bar__back">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M15 18l-6-6 6-6"/></svg>
                </a>
                <span class="top-bar__title">@ViewData["PageTitle"]</span>
                <div style="width:24px"></div>
            }
            else
            {
                <a href="/" class="top-bar__logo">Clothify</a>
                <div class="top-bar__actions">
                    <a href="/Products/Search" class="btn-icon hide-mobile">
                        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/></svg>
                    </a>
                    <a href="/Cart" class="btn-icon" style="position:relative">
                        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 01-8 0"/></svg>
                        <span class="bottom-nav__badge cart-count" style="display:none">0</span>
                    </a>
                </div>
            }
        </header>
    }

    <main>
        @RenderBody()
    </main>

    @if (ViewData["HideLayout"] == null && ViewData["HideNav"] == null)
    {
        <!-- Bottom Navigation -->
        <nav class="bottom-nav">
            <a href="/" class="bottom-nav__item @(ViewData["ActiveNav"]?.ToString() == "home" ? "active" : "")">
                <svg class="nav-icon" viewBox="0 0 24 24" fill="@(ViewData["ActiveNav"]?.ToString() == "home" ? "currentColor" : "none")" stroke="currentColor" stroke-width="2"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/></svg>
                <span>Home</span>
            </a>
            <a href="/Products/Search" class="bottom-nav__item @(ViewData["ActiveNav"]?.ToString() == "search" ? "active" : "")">
                <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/></svg>
                <span>Search</span>
            </a>
            <a href="/Cart" class="bottom-nav__item @(ViewData["ActiveNav"]?.ToString() == "cart" ? "active" : "")" style="position:relative">
                <svg class="nav-icon" viewBox="0 0 24 24" fill="@(ViewData["ActiveNav"]?.ToString() == "cart" ? "currentColor" : "none")" stroke="currentColor" stroke-width="2"><path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 01-8 0"/></svg>
                <span class="bottom-nav__badge cart-count" style="display:none">0</span>
                <span>Cart</span>
            </a>
            <a href="/Profile" class="bottom-nav__item @(ViewData["ActiveNav"]?.ToString() == "profile" ? "active" : "")">
                <svg class="nav-icon" viewBox="0 0 24 24" fill="@(ViewData["ActiveNav"]?.ToString() == "profile" ? "currentColor" : "none")" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                <span>Profile</span>
            </a>
        </nav>
    }

    <!-- Install App Banner -->
    <div id="pwa-install" style="display:none;position:fixed;bottom:calc(var(--nav-height) + 8px);left:16px;right:16px;z-index:500;background:var(--color-primary);color:white;padding:12px 16px;border-radius:var(--radius-lg);box-shadow:var(--shadow-xl);align-items:center;gap:12px">
        <div style="flex:1">
            <div style="font-weight:600;font-size:14px">Install Clothify</div>
            <div style="font-size:12px;opacity:0.8">Add to home screen for the best experience</div>
        </div>
        <button onclick="installPWA()" style="background:white;color:var(--color-primary);border:none;padding:8px 16px;border-radius:var(--radius-md);font-weight:600;font-size:13px;cursor:pointer">Install</button>
        <button onclick="document.getElementById('pwa-install').style.display='none'" style="background:none;border:none;color:white;font-size:18px;cursor:pointer;padding:4px">&times;</button>
    </div>

    <script src="~/js/clothify.js"></script>
    <script>
        // Register Service Worker
        if ('serviceWorker' in navigator) {
            navigator.serviceWorker.register('/service-worker.js')
                .then(reg => console.log('SW registered'))
                .catch(err => console.log('SW failed:', err));
        }

        // PWA Install Prompt
        let deferredPrompt;
        window.addEventListener('beforeinstallprompt', (e) => {
            e.preventDefault();
            deferredPrompt = e;
            document.getElementById('pwa-install').style.display = 'flex';
        });

        function installPWA() {
            if (deferredPrompt) {
                deferredPrompt.prompt();
                deferredPrompt.userChoice.then(choice => {
                    document.getElementById('pwa-install').style.display = 'none';
                    deferredPrompt = null;
                });
            }
        }

        window.addEventListener('appinstalled', () => {
            document.getElementById('pwa-install').style.display = 'none';
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
